<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css" />
        <title>Rootstock</title>
        <style>
            pre[class*="language-"] {
                margin: 0 !important;
                border-radius: 0.5rem !important;
                overflow-x: auto !important;
            }
            .cluster-panel { display: none; }
            .cluster-panel.active { display: block; }
            .sidebar-item.active { background-color: #3b82f6; color: white; }
            .sidebar-item.active .env-count { background-color: rgba(255,255,255,0.2); color: white; }
            @media (max-width: 767px) {
                .sidebar { transform: translateX(-100%); }
                .sidebar.open { transform: translateX(0); }
            }
        </style>
    </head>
    <body class="bg-gray-100 min-h-screen">
        <div class="flex h-screen overflow-hidden">
            <!-- Mobile Header -->
            <div class="md:hidden fixed top-0 left-0 right-0 z-30 bg-gray-900 text-white px-4 py-3 flex items-center justify-between">
                <button onclick="toggleSidebar()" class="p-1">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
                <h1 class="text-lg font-bold">Rootstock</h1>
                <div class="w-6"></div>
            </div>

            <!-- Sidebar Overlay -->
            <div id="sidebar-overlay" onclick="toggleSidebar()" class="md:hidden fixed inset-0 bg-black/50 z-30 hidden"></div>

            <!-- Sidebar -->
            <aside id="sidebar" class="sidebar fixed md:static inset-y-0 left-0 z-40 w-64 md:w-72 bg-gray-900 text-gray-100 flex flex-col transition-transform duration-300 md:transform-none">
                <div class="p-4 md:p-6 border-b border-gray-700">
                    <div class="flex items-center justify-between">
                        <h1 class="text-xl font-bold text-white">Rootstock</h1>
                        <a href="https://github.com/Garden-AI/rootstock" target="_blank" rel="noopener noreferrer" class="opacity-60 hover:opacity-100 transition-opacity" title="View on GitHub">
                            <img src="https://cdn.simpleicons.org/github/white" alt="GitHub" class="w-5 h-5" />
                        </a>
                    </div>
                    <p class="text-sm text-gray-400 mt-1">Cluster Configurations</p>
                </div>
                <nav class="flex-1 overflow-y-auto py-4">
                    {% for manifest in manifests %}
                    <button
                        onclick="selectCluster('{{ loop.index0 }}')"
                        id="sidebar-{{ loop.index0 }}"
                        class="sidebar-item w-full text-left px-4 md:px-6 py-3 hover:bg-gray-800 transition-colors flex items-center justify-between gap-2 group"
                    >
                        <div class="min-w-0 flex-1">
                            <div class="font-medium truncate">{{ manifest.cluster }}</div>
                            <div class="text-xs text-gray-500 group-hover:text-gray-400">v{{ manifest.rootstock_version }}</div>
                        </div>
                        <span class="env-count px-2 py-0.5 text-xs bg-gray-700 rounded-full shrink-0">{{ manifest.environments | length }}</span>
                    </button>
                    {% else %}
                    <div class="px-4 md:px-6 py-4 text-gray-500 text-sm">No clusters found</div>
                    {% endfor %}
                </nav>
                <div class="p-4 border-t border-gray-700 text-xs text-gray-500">
                    Deployed on {{ manifests | length }} cluster{{ 's' if manifests | length != 1 else '' }}
                </div>
            </aside>

            <!-- Main Content -->
            <main class="flex-1 overflow-y-auto pt-14 md:pt-0 min-w-0">
                {% if manifests %}
                <!-- Empty state when no cluster selected -->
                <div id="empty-state" class="h-full flex items-center justify-center text-gray-400 p-4">
                    <div class="text-center">
                        <p class="text-base md:text-lg">Select a cluster from the sidebar</p>
                    </div>
                </div>

                {% for manifest in manifests %}
                <div id="cluster-{{ loop.index0 }}" class="cluster-panel p-4 md:p-8">
                    <!-- Cluster Header -->
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 md:p-6 mb-4 md:mb-6">
                        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
                            <div class="min-w-0">
                                <h2 class="text-xl md:text-2xl font-bold text-gray-900 truncate">{{ manifest.cluster }}</h2>
                                <p class="text-gray-500 mt-1 text-sm md:text-base">Rootstock v{{ manifest.rootstock_version }}</p>
                            </div>
                            <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm font-medium shrink-0 self-start">
                                {{ manifest.environments | length }} env{{ 's' if manifest.environments | length != 1 else '' }}
                            </span>
                        </div>
                        <div class="mt-4 md:mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 text-sm">
                            <div class="bg-gray-50 rounded-lg p-3 min-w-0 sm:col-span-2 lg:col-span-1">
                                <div class="flex items-center justify-between">
                                    <span class="text-gray-500 text-xs uppercase tracking-wide">Root</span>
                                    <button
                                        onclick="navigator.clipboard.writeText('{{ manifest.root }}').then(() => { this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Copy', 1500); })"
                                        class="px-2 py-0.5 text-xs text-gray-500 hover:text-gray-700 hover:bg-gray-200 rounded transition-colors cursor-pointer"
                                    >Copy</button>
                                </div>
                                <div class="font-medium text-gray-900 mt-1 truncate font-mono text-xs" title="{{ manifest.root }}">{{ manifest.root }}</div>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-3">
                                <div class="text-gray-500 text-xs uppercase tracking-wide">Python</div>
                                <div class="font-medium text-gray-900 mt-1">{{ manifest.python_version }}</div>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-3 min-w-0">
                                <div class="text-gray-500 text-xs uppercase tracking-wide">Maintainer</div>
                                <div class="font-medium text-gray-900 mt-1 truncate">{{ manifest.maintainer.name }}</div>
                                <a href="mailto:{{ manifest.maintainer.email }}" class="text-blue-600 hover:text-blue-800 text-xs truncate block" title="{{ manifest.maintainer.email }}">{{ manifest.maintainer.email }}</a>
                            </div>
                            <div class="bg-gray-50 rounded-lg p-3 min-w-0">
                                <div class="text-gray-500 text-xs uppercase tracking-wide">Last Updated</div>
                                <div class="font-medium text-gray-900 mt-1 truncate" title="{{ manifest.last_updated }}">{{ manifest.last_updated }}</div>
                            </div>
                        </div>
                    </div>

                    <!-- Environments -->
                    <h3 class="text-lg font-semibold text-gray-800 mb-3 md:mb-4">Environments</h3>
                    <div class="space-y-3 md:space-y-4">
                        {% for env_name, env in manifest.environments.items() %}
                        <details class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden group">
                            <summary class="px-4 md:px-6 py-3 md:py-4 cursor-pointer hover:bg-gray-50 transition-colors flex items-center justify-between gap-2">
                                <div class="flex items-center gap-2 md:gap-4 min-w-0">
                                    <span class="text-base md:text-lg font-medium text-gray-800 truncate">{{ env_name }}</span>
                                    {% if env.status == 'ready' %}
                                    <span class="px-2 py-0.5 md:px-2.5 md:py-1 text-xs font-medium bg-green-100 text-green-700 rounded-full shrink-0">Ready</span>
                                    {% else %}
                                    <span class="px-2 py-0.5 md:px-2.5 md:py-1 text-xs font-medium bg-yellow-100 text-yellow-700 rounded-full shrink-0">{{ env.status }}</span>
                                    {% endif %}
                                </div>
                                <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </summary>

                            <div class="px-4 md:px-6 py-4 md:py-5 border-t border-gray-100 bg-gray-50">
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 md:gap-4 mb-4 md:mb-5 text-sm">
                                    <div>
                                        <span class="text-gray-500">Built:</span>
                                        <span class="ml-2 text-gray-900">{{ env.built_at }}</span>
                                    </div>
                                    <div>
                                        <span class="text-gray-500">Python:</span>
                                        <span class="ml-2 text-gray-900">{{ env.python_requires }}</span>
                                    </div>
                                </div>

                                {% if env.source %}
                                <details class="mb-4 md:mb-5 border border-gray-200 rounded-lg overflow-hidden">
                                    <summary class="px-3 py-2 bg-white hover:bg-gray-50 cursor-pointer flex items-center justify-between">
                                        <h4 class="font-medium text-gray-700">Source Code</h4>
                                        <div class="flex items-center gap-2">
                                            <button
                                                onclick="event.stopPropagation(); navigator.clipboard.writeText(this.closest('details').querySelector('pre').textContent).then(() => { this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Copy', 1500); })"
                                                class="px-3 py-1 text-xs font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-md transition-colors cursor-pointer"
                                            >Copy</button>
                                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                            </svg>
                                        </div>
                                    </summary>
                                    <div class="overflow-x-auto border-t border-gray-200">
                                        <pre class="language-python"><code>{{ env.source }}</code></pre>
                                    </div>
                                </details>
                                {% endif %}

                                {% if env.dependencies %}
                                <div class="mb-4 md:mb-5">
                                    <h4 class="font-medium text-gray-700 mb-2 md:mb-3">Dependencies ({{ env.dependencies | length }})</h4>
                                    <div class="inline-block bg-white border border-gray-200 rounded-lg overflow-hidden">
                                        <table class="text-xs font-mono">
                                            <tbody class="divide-y divide-gray-100">
                                                {% for pkg, version in env.dependencies.items() %}
                                                <tr class="hover:bg-gray-50">
                                                    <td class="px-3 py-2 text-gray-900">{{ pkg }}</td>
                                                    <td class="px-3 py-2 text-gray-500">{{ version }}</td>
                                                </tr>
                                                {% endfor %}
                                            </tbody>
                                            <tfoot class="border-t border-gray-200 bg-gray-50">
                                                <tr>
                                                    <td colspan="2" class="px-3 py-2">
                                                        <button
                                                            onclick="copyDeps(this, '{% for pkg, version in env.dependencies.items() %}{{ pkg }}=={{ version }}\n{% endfor %}')"
                                                            class="text-xs text-blue-600 hover:text-blue-800 cursor-pointer"
                                                        >Copy</button>
                                                    </td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                                {% endif %}

                                {% if env.checkpoints %}
                                <div>
                                    <h4 class="font-medium text-gray-700 mb-2 md:mb-3">Checkpoints</h4>
                                    <div class="flex flex-wrap gap-1.5 md:gap-2">
                                        {% for checkpoint in env.checkpoints %}
                                        <span class="px-2 md:px-3 py-1 md:py-1.5 bg-purple-50 text-purple-700 rounded-lg text-xs border border-purple-100 break-all">{{ checkpoint }}</span>
                                        {% endfor %}
                                    </div>
                                </div>
                                {% endif %}
                            </div>
                        </details>
                        {% endfor %}
                    </div>
                </div>
                {% endfor %}
                {% else %}
                <div class="h-full flex items-center justify-center text-gray-400">
                    <div class="text-center">
                        <svg class="w-16 h-16 mx-auto mb-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                        </svg>
                        <p class="text-lg">No cluster configurations found</p>
                    </div>
                </div>
                {% endif %}
            </main>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js"></script>
        <script>
            function copyDeps(btn, text) {
                navigator.clipboard.writeText(text.trim()).then(() => {
                    btn.textContent = 'Copied!';
                    setTimeout(() => btn.textContent = 'Copy All', 1500);
                });
            }

            function toggleSidebar() {
                const sidebar = document.getElementById('sidebar');
                const overlay = document.getElementById('sidebar-overlay');
                sidebar.classList.toggle('open');
                overlay.classList.toggle('hidden');
            }

            function selectCluster(index) {
                // Hide empty state
                const emptyState = document.getElementById('empty-state');
                if (emptyState) emptyState.style.display = 'none';

                // Hide all panels and deactivate sidebar items
                document.querySelectorAll('.cluster-panel').forEach(p => p.classList.remove('active'));
                document.querySelectorAll('.sidebar-item').forEach(s => s.classList.remove('active'));

                // Show selected panel and activate sidebar item
                document.getElementById('cluster-' + index).classList.add('active');
                document.getElementById('sidebar-' + index).classList.add('active');

                // Close sidebar on mobile
                if (window.innerWidth < 768) {
                    toggleSidebar();
                }

                // Re-run Prism highlighting for the newly visible panel
                Prism.highlightAllUnder(document.getElementById('cluster-' + index));
            }
        </script>
    </body>
</html>
